"HDFP", "mixed", 51, 55, 5.0, "None", "mixed", 5.0, 102, 5485, 158, 5455, "CD",
"Oslo", "all patients had entry DBP < 110 mm Hg", 45, 100, 5.5, "None", "90-109", 10.0, 0, 406, 5, 379, "HZ",
"ANBPS", "all patients had entry DBP < 110 mm Hg", 50, 63, 4.0, "Single", "95-109", 6.0, 13, 1721, 22, 1706, "CZ",
"MRC", "all patients had entry DBP < 110 mm Hg", 52, 52, 5.0, "Single", "95-109", 6.0, 60, 8700, 109, 8654, "BF or PR",
"VA (90-114)", "all patients had entry DBP <= 115 mm Hg", 51, 100, 3.3, "Double", "90-114", 19.0, 5, 186, 20, 194, "HZ + RE + HD",
"USPHS", "all patients had entry DBP <= 115 mm Hg", 44, 80, 7.0, "Double", "90-114", 10.0, 1, 193, 6, 196, "CZ + RU",
"HSCSG", "all patients had entry DBP <= 115 mm Hg", 59, 41, 2.3, "Double", "90-115", 12.0, 43, 233, 52, 219, "MC + DS",
"VA (115-129)", "all patients had entry DBP > 115 mm Hg", 51, 100, 1.5, "Double", "115-129", 27.0, 5, 70, 20, 73, "HZ + RE + HD",
"Wolff", "all patients had entry DBP > 115 mm Hg", 49, 32, 1.4, "Double", "100-130", 20.0, 2, 45, 1, 42, "RE",
"Barraclough", "all patients had entry DBP > 115 mm Hg", 56, 43, 2.0, "Single", "100-120", 13.0, 0, 58, 0, 58, "BF or MD",
# "Carter", "all patients had entry DBP > 115 mm Hg", NA, 57, 4.0, "None", ">=110", NA_real_, 10, 49, 21, 48, "TH",
