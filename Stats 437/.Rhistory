n_total = n_t + n_c
)
View(collins_bp)
collins_bp %>%
dplyr::select(trial, age, male_pct, follow_up, blinding, entry_dbp, dbp_diff, e_t, n_t, e_c, n_c, main_drugs) %>%
kable(
digits = 2,
col.names = c("Trial", "Age", "Male %", "Follow (yr)", "Blinding",
"Entry DBP", "DBP diff", "Stroke Tx", "Tx N",
"Stroke Ctl", "Ctl N", "Drugs"),
booktabs = TRUE,
longtable = FALSE,
align = "lccccccrrrrll"
) %>%
kable_styling(font_size = 7, latex_options = c("scale_down"))
# Create the 2 x 2 table columns needed by escalc()
# ai = events in treatment
# bi = non-events in treatment
# ci = events in control
# di = non-events in control
dat_es <- escalc(
measure = "OR",
ai = e_t,
bi = n_t - e_t,
ci = e_c,
di = n_c - e_c,
data = collins_bp,
add = 0.5,     ## this is a continuity correction for the 2x2 table
## this continuity correction is only applied to all.
to = "all",
drop00 = FALSE
)
# Inspect the study-level log(OR) values and variances
dat_es %>%
dplyr::select(trial, dbp_diff, yi, vi)
re_mod <- rma(yi = yi, vi = vi, data = dat_es, method = "FE")
summary(re_mod)
meta_mod <- rma(
yi = yi,
vi = vi,
mods = ~ dbp_diff,
data = dat_es,
method = "FE"
)
summary(meta_mod)
?rma
View(dat_es)
tibble(
model = c("Random effects", "Meta-regression"),
tau2 = c(re_mod$tau2, meta_mod$tau2),
I2 = c(re_mod$I2, meta_mod$I2),
R2_analog = c(NA, meta_mod$R2)
)
regplot(
meta_mod,
xlab = "DBP reduction (mm Hg)",
ylab = "log(OR)",
pch = 21,
bg = "steelblue"
)
